# EditorConfig - Universal code style settings
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{py,pyw}]
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,yaml,yml,html,css,scss}]
indent_style = space
indent_size = 2

[*.{lua,vim}]
indent_style = space
indent_size = 2

[*.{md,markdown}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{sh,bash,zsh,fish}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
